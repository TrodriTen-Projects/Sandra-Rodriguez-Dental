# Public analytics / tracking IDs.
#
# NOTE: these are NOT secrets. NEXT_PUBLIC_* variables are inlined into the
# client bundle at build time and are visible in the browser. They live here
# only to keep configuration out of source code and to allow different IDs per
# environment (e.g. staging vs production).
#
# Local dev:        copy this file to `.env.local` and fill in the values.
# Cloudflare Pages: set the same variables under
#                   Settings → Environment variables (Production & Preview).

NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_FB_PIXEL_ID=
NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_ID=
NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_LABEL=
